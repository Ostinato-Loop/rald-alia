# RALD ALIA — Environment Variables
# Copy to .env and fill in values before running docker-compose

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=raldalia
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=raldalia
DATABASE_URL=postgresql://raldalia:CHANGE_ME_strong_password@postgres:5432/raldalia

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
MACHINE_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
CREDENTIAL_SIGNING_KEY=CHANGE_ME_generate_with_openssl_rand_base64_64

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
TERMII_API_KEY=CHANGE_ME

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
