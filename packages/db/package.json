{
  "name": "@rald-alia/db",
  "version": "0.1.0",
  "private": true,
  "description": "ALIA platform database schema, client, and migrations (Drizzle ORM)",
  "main": "./src/index.ts",
  "scripts": {
    "build":      "tsc",
    "typecheck":  "tsc --noEmit",
    "seed":       "ts-node --transpile-only src/seed.ts",
    "migrate":    "drizzle-kit migrate",
    "push":       "drizzle-kit push",
    "studio":     "drizzle-kit studio",
    "generate":   "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.1",
    "postgres":    "^3.4.5",
    "dotenv":      "^16.4.7"
  },
  "devDependencies": {
    "drizzle-kit":  "^0.30.4",
    "typescript":   "^5.7.3",
    "@types/node":  "^22.0.0",
    "ts-node":      "^10.9.2"
  },
  "engines": { "node": ">=18.0.0" }
}
