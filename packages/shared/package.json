{
  "name": "@rald-alia/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":           { "import": "./dist/index.js",      "require": "./dist/index.js",      "types": "./dist/index.d.ts" },
    "./security":  { "import": "./dist/security.js",   "require": "./dist/security.js",   "types": "./dist/security.d.ts" },
    "./validate":  { "import": "./dist/validate.js",   "require": "./dist/validate.js",   "types": "./dist/validate.d.ts" },
    "./machineAuth": { "import": "./dist/machineAuth.js", "require": "./dist/machineAuth.js", "types": "./dist/machineAuth.d.ts" },
    "./requestId": { "import": "./dist/requestId.js",  "require": "./dist/requestId.js",  "types": "./dist/requestId.d.ts" }
  },
  "typesVersions": {
    "*": {
      "security":    ["./dist/security.d.ts",    "./src/security.ts"],
      "validate":    ["./dist/validate.d.ts",    "./src/validate.ts"],
      "machineAuth": ["./dist/machineAuth.d.ts", "./src/machineAuth.ts"],
      "requestId":   ["./dist/requestId.d.ts",   "./src/requestId.ts"]
    }
  },
  "scripts": {
    "build":     "tsc",
    "dev":       "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "express":            "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet":             "^8.0.0",
    "jsonwebtoken":       "^9.0.2",
    "ulid":               "^2.3.0",
    "zod":                "^3.24.1"
  },
  "devDependencies": {
    "@types/cors":         "^2.8.17",
    "@types/express":      "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node":         "^22.0.0",
    "typescript":          "^5.7.3"
  }
}
