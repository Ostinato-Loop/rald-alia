# ALIA Gateway — environment variables
# Copy to .env and fill in values

PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Upstream service URLs
IDENTITY_SERVICE_URL=http://localhost:4001
NOTIFICATION_SERVICE_URL=http://localhost:4002
ALIAS_SERVICE_URL=http://localhost:4003
ROUTING_SERVICE_URL=http://localhost:4004
TRUST_SERVICE_URL=http://localhost:4005
FRAUD_SERVICE_URL=http://localhost:4006
CONSENT_SERVICE_URL=http://localhost:4007
VERIFICATION_SERVICE_URL=http://localhost:4008
AUDIT_SERVICE_URL=http://localhost:4009
DIRECTORY_SERVICE_URL=http://localhost:4010
MERCHANT_SERVICE_URL=http://localhost:4011
GOVERNANCE_SERVICE_URL=http://localhost:4012
RESOLUTION_ENGINE_URL=http://localhost:4013
