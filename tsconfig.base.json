{
  "compilerOptions": {
    "target":                          "ES2020",
    "module":                          "commonjs",
    "lib":                             ["ES2020"],
    "strict":                          true,
    "esModuleInterop":                 true,
    "declaration":                     true,
    "declarationMap":                  true,
    "sourceMap":                       true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "moduleResolution":                "node"
  }
}
